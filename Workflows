yaml
name: Pair WhatsApp
on:
  workflow_dispatch:
    inputs:
      phone_number:
        description: 'Your WhatsApp number: 254731070008'
        required: true

jobs:
  pair:
    runs-on: ubuntu-latest
    timeout-minutes: 3
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - run: npm install
      - run: echo "${{ github.event.inputs.phone_number }}" | node pair.js
```
